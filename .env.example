# ---- Postgres (Neon) ----
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ---- Binotel ----
BINOTEL_API_KEY=
BINOTEL_API_SECRET=
BINOTEL_BASE_URL=https://api.binotel.com/api/4.0

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# used for classification, manager identification, report summaries, and KB answers
OPENAI_ANALYZE_MODEL=gpt-4o-mini
# embeddings for the knowledge base (bot "Поставити питання"); 1536-dim, cheap
OPENAI_EMBED_MODEL=text-embedding-3-small
# leave EMPTY (recommended): transcribe with a Ukrainian bias, then detect spoken-vs-written
# language and re-transcribe if they disagree (fixes Ukrainian-with-surzhyk being written as
# Russian). Set to a fixed code (uk/ru) only to force one language and skip detection.
CALL_LANGUAGE=

# ---- Ingest cron (src/jobs) ----
JOB_TYPE=poll
# how far back to look on the very first poll run ever (checkpoint takes over after that)
POLL_WINDOW_MINUTES=20
# shared handsets (internal numbers) where the manager is identified from the recording
SHARED_EXTENSIONS=901,902
# retries for a call stuck in the pending queue before giving up and alerting
MAX_PENDING_ATTEMPTS=20

# ---- Single Telegram bot (interactive report bot + ingest alerts) ----
# ONE clean bot from @BotFather. Must NOT be a bot whose webhook belongs to another system
# (e.g. CarBook) - getUpdates would break it. Used by both src/bot and the ingest's alerts.
TELEGRAM_BOT_TOKEN=
# owner chat id — alerts + default report recipient + default bot allowlist
TELEGRAM_CHAT_ID=
# optional separate chat for failure alerts (default: TELEGRAM_CHAT_ID)
TELEGRAM_ADMIN_CHAT_ID=
# who may use the interactive bot (comma-separated user ids; default: TELEGRAM_CHAT_ID)
BOT_ALLOWED_CHAT_IDS=
# where auto-reports are sent (default: TELEGRAM_CHAT_ID)
BOT_REPORT_CHAT_ID=
# Kyiv-local auto-report times
BOT_REPORT_TIMES=13:00,19:30
