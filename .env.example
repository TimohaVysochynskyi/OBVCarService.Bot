BINOTEL_API_KEY=
BINOTEL_API_SECRET=
BINOTEL_BASE_URL=https://api.binotel.com/api/4.0

OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_ANALYZE_MODEL=gpt-4o-mini
# leave empty to auto-detect - calls are a mix of uk/ru, forcing one risks mistranslation
CALL_LANGUAGE=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# optional separate chat for failure/pending-call alerts; falls back to TELEGRAM_CHAT_ID
TELEGRAM_ADMIN_CHAT_ID=

# Neon (or any) Postgres connection string
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# how far back to look on the very first poll run ever (checkpoint takes over after that)
POLL_WINDOW_MINUTES=20

# comma-separated Kyiv-local hours (0-23) at which a report gets sent, checked on every poll
# run. Each report covers everything since the previous one (not a fixed 24h window).
REPORT_HOURS=12,19

# how many times to retry a call stuck in the pending queue before giving up and alerting
MAX_PENDING_ATTEMPTS=20

# Google Sheets stats sync - leave both empty to dry-run (logs to console instead)
# GOOGLE_SERVICE_ACCOUNT_JSON must be the full service-account key JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=

# JOB_TYPE is set per Render Cron Job service, not stored here: poll | report
JOB_TYPE=poll
