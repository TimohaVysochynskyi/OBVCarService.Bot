# ---- Postgres ----
# Now a LOCAL Postgres on the VPS (localhost). SSL is auto-disabled for localhost/127.0.0.1 or an
# explicit sslmode=disable; a remote/managed DB (e.g. Neon, sslmode=require) still uses SSL.
DATABASE_URL=postgres://obvbot:password@localhost:5432/obvbot

# ---- Binotel ----
BINOTEL_API_KEY=
BINOTEL_API_SECRET=
BINOTEL_BASE_URL=https://api.binotel.com/api/4.0

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# used for classification, manager identification, per-call behavior MAP, KB answers, speaker roles
OPENAI_ANALYZE_MODEL=gpt-4o-mini
# stronger model for the report REDUCE (aggregating cached behaviors into evidence-backed findings).
# Runs rarely (per report), so a higher tier is affordable; empty falls back to gpt-4o.
OPENAI_REPORT_MODEL=gpt-4o
# embeddings for the knowledge base (bot "База знань"); 1536-dim, cheap
OPENAI_EMBED_MODEL=text-embedding-3-small
# CALL_LANGUAGE: force the spoken language (uk/ru) — applies to BOTH ElevenLabs (language_code)
# and the OpenAI fallback. Leave EMPTY to auto-detect. For the OpenAI fallback, empty also enables
# the spoken-vs-written re-transcription fix (Ukrainian-with-surzhyk written as Russian).
CALL_LANGUAGE=

# ---- ElevenLabs (Speech-to-Text: transcription + speaker diarization in one call) ----
# PRIMARY transcriber. Produces a ready "Менеджер:/Клієнт:" dialogue at ingest, so the archive
# shows it instantly. If empty (or the API fails/quota runs out), the bot falls back to OpenAI
# transcription (plain, no diarization). For ~50 calls/day the "Scale" plan is the fit (STT is
# 330 credits/min; see docs). Header used: xi-api-key.
ELEVENLABS_API_KEY=
# scribe_v1 (GA) by default; set scribe_v2 to try the newer model.
ELEVENLABS_STT_MODEL=scribe_v1
# max speakers hint — a phone call is 2 parties; raise only for multi-party calls.
ELEVENLABS_NUM_SPEAKERS=2

# ---- Evidence report audio clips (bot "Доказовий звіт") ----
# Negative findings are backed by short audio clips cut around each quoted line with SYSTEM ffmpeg
# (install it on the VPS — see DEPLOY.md). If ffmpeg is missing the report still works, just text-only.
# FFMPEG_PATH: override if ffmpeg isn't on PATH. AUDIO_CLIP_PAD_SEC: seconds of context each side.
FFMPEG_PATH=ffmpeg
AUDIO_CLIP_PAD_SEC=3
# one-off backfill (npm run backfill:analysis): last N calls per person operator re-transcribed for
# timecodes + per-call behavior map, so old calls also get audio evidence.
BACKFILL_LIMIT=30

# ---- Ingest cron (src/jobs) ----
JOB_TYPE=poll
# how far back to look on the very first poll run ever (checkpoint takes over after that)
POLL_WINDOW_MINUTES=20
# shared handsets (internal numbers) where the manager is identified from the recording
SHARED_EXTENSIONS=901,902
# retries for a call stuck in the pending queue before giving up and alerting
MAX_PENDING_ATTEMPTS=20

# ---- Single Telegram bot (interactive report bot + ingest alerts) ----
# ONE clean bot from @BotFather. Must NOT be a bot whose webhook belongs to another system
# (e.g. CarBook) - getUpdates would break it. Used by both src/bot and the ingest's alerts.
TELEGRAM_BOT_TOKEN=
#
# DIRECTORS (bootstrap) — comma-separated owner USER ids seeded as "director" in bot_users at
# startup so nobody is locked out on a fresh DB. This is NOT a live allowlist — after first run,
# access is managed in-bot via the "Ролі" block. Non-positive (group) ids are skipped.
# (This is the ONLY Telegram chat id left in env. Where failure alerts and daily reports are sent
# is now configured in the bot itself: /settings → "Сповіщення про поломки" / "Щоденні звіти",
# stored in the DB as recipient lists so a message can fan out to several people.)
TELEGRAM_BOOTSTRAP_CHAT_IDS=
# NB: auto-report TIMES are no longer in env — they are managed in the bot (/settings → "Час
# звітів", stored in the DB). Default until edited: 13:00 and 19:30 (Kyiv). The scheduler is an
# in-process interval inside the bot worker, NOT a separate cron.
# optional display aliases: show a raw manager_name (a bare number/phone) under a human name in
# the bot UI and reports. Comma-separated "number=Name" pairs, merged over the built-in
# default (0674738200=Богдан, the director's mobile). Display-only — the DB is not modified.
OPERATOR_ALIASES=
